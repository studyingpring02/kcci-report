# Anthropic API 키 (필수)
# 발급: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-여기에_입력

# 네이버 검색 API (선택 — 없으면 Claude 웹검색으로 대체)
# 발급: https://developers.naver.com → Application → 애플리케이션 등록
#       사용 API: "검색" 체크 / 환경: WEB / URL: http://localhost:3000
NAVER_CLIENT_ID=여기에_Client_ID
NAVER_CLIENT_SECRET=여기에_Client_Secret
